    "@tanstack/react-query": "^5.28.0",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-start": "^1.167.44",
    "isbot": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.10.0"
  },
  "devDependencies": {
    "@tanstack/react-router-devtools": "^1.166.13",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.2.1",
    "nitro": "^3.0.0",
    "sass": "^1.99.0",
    "typescript": "^5.4.2",
    "vite": "^7.0.0",
    "wrangler": "^4.85.0"
