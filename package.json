{
  "name": "nexpr",
  "version": "1.0.0",
  "description": "Unlock your next PR - Data-driven running performance platform",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "NODE_ENV=production NITRO_PRESET=cloudflare-module vite build",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
